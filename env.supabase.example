# Supabase Environment Variables Example
# Copy the relevant variables to your .env file

# Frontend Configuration (.env or .env.local)
VITE_API_BASE_URL=https://your-project-ref.supabase.co/functions/v1

# Supabase Client Configuration (for direct database access)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API Key (for polygon drawing)
VITE_GOOGLE_MAPS_API_KEY=AIzaSyDbDOCUbGH8ygOBMxOGPBW2bNdCWT4uSAA

# Gemini API Key (for AI Field Brief)
VITE_GEMINI_API_KEY=AIzaSyA8ZnhK4bKe1qbFLQI72ZzBEBx34vOhH5s

# For Local Development
# VITE_API_BASE_URL=http://localhost:54321/functions/v1
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Supabase Project Configuration (for deployment scripts)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-access-token

# Google Earth Engine Credentials (Set via Supabase CLI or Dashboard)
# These should be set as Supabase Secrets, not in .env files

# Option 1: Use complete JSON credentials (recommended)
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'

# Option 2: Use individual environment variables
# GOOGLE_PROJECT_ID=your-project-id
# GOOGLE_PRIVATE_KEY_ID=your-private-key-id
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account@project.iam.gserviceaccount.com









