{
    "name": "sentinel-agro-functions",
    "version": "1.0.0",
    "description": "Firebase Cloud Functions for Sentinel Agro Insight",
    "main": "lib/index.js",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "18"
    },
    "dependencies": {
        "@google/earthengine": "^1.6.13",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "firebase-admin": "^11.11.1",
        "firebase-functions": "^4.9.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.15",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "typescript": "^5.3.0"
    },
    "private": true
}
